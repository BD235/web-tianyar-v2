# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc & OS
.DS_Store
Thumbs.db
*.pem

# debug & logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.template

# vercel & build cache
.vercel
.turbo
.cache
.swc

# IDEs & Editors
.vscode/
.idea/
.gemini/
.cursor/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase local (if using CLI)
supabase/.temp/
supabase/.branches/
supabase/functions/.env

# --- CUSTOM IGNORES ---
# Script uji coba / skrip sementara lokal
*.mjs.tmp
test-*.mjs
test-*.js

# Laporan audit lokal
Audit_Performa_dan_Keamanan_Tianyar.pdf
*.pdf

# Folder setelan agen AI lokal
.agents/
